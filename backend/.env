# Flask Configuration
FLASK_DEBUG=True
PORT=5000

# Security Keys (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=real_estate_db
MONGODB_TIMEOUT_MS=5000
USE_MOCK_DB_ON_FAILURE=True

# CORS / Frontend
# No trailing slashes! Flask-CORS is strict about this.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,https://rerealestate.vercel.app
