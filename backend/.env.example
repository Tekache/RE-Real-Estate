# Flask Configuration
FLASK_DEBUG=True
PORT=5000

# Security Keys (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=replace-with-strong-random-secret
JWT_SECRET_KEY=replace-with-strong-random-jwt-secret

# MongoDB Configuration
# Local development:
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=real_estate_db
MONGODB_TIMEOUT_MS=5000
USE_MOCK_DB_ON_FAILURE=True

# Production (Render + MongoDB Atlas) example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DATABASE=real_estate_db
# MONGODB_TIMEOUT_MS=10000
# USE_MOCK_DB_ON_FAILURE=False

# CORS / Frontend
FRONTEND_URL=http://localhost:5173
# Optional (overrides FRONTEND_URL):
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Optional: Email Configuration (for contact form notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=your-email@gmail.com

# Optional: File Upload Configuration
# UPLOAD_FOLDER=uploads
# MAX_CONTENT_LENGTH=16777216  # 16MB max file size

# Optional: Redis (for caching/sessions)
# REDIS_URL=redis://localhost:6379/0
